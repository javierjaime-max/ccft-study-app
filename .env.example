# Supabase — required
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Anthropic — set as Supabase secret, NOT a Vite env var
# Run: supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_API_KEY is server-side only (Edge Function) — never expose in browser
